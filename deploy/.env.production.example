# URL pública (sem barra no final) — usada pelo frontend e CORS
PUBLIC_URL=http://SEU_IP_OU_DOMINIO

SECRET_KEY=CHANGE_ME_SECRET
DEBUG=False

DATABASE_URL=sqlite:///data/db.sqlite3

ALLOWED_HOSTS=SEU_IP_OU_DOMINIO
CORS_ORIGINS=http://SEU_IP_OU_DOMINIO
CSRF_TRUSTED_ORIGINS=http://SEU_IP_OU_DOMINIO

# HTTP sem HTTPS: use false até configurar certificado
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
BEHIND_PROXY=false

ADMIN_EMAIL=admin@ssma.com.br
ADMIN_PASSWORD=ALTERE_ESTA_SENHA
ADMIN_NAME=Administrador SSMA
LOG_LEVEL=INFO

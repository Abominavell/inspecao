# Produção — inspecao.iadvh.org.br (CloudPanel)
# Copie para frontend/.env.production

NEXT_PUBLIC_API_URL=https://apiinspecao.iadvh.org.br
PORT=3011
HOSTNAME=127.0.0.1

# Auth.js / Microsoft Entra ID
AUTH_SECRET=CHANGE_ME_LONG_RANDOM
AUTH_URL=https://inspecao.iadvh.org.br
AUTH_TRUST_HOST=true
NEXTAUTH_URL=https://inspecao.iadvh.org.br
NEXTAUTH_SECRET=CHANGE_ME_LONG_RANDOM

AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=

# Scope da API Django registrada no Entra (ex.: api://<client-id>/access_as_user)
AUTH_ENTRA_API_SCOPE=

# Feature flag — exibe "Entrar com Microsoft" no /login
NEXT_PUBLIC_AUTH_ENTRA_ENABLED=true

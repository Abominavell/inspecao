# Produção — apiinspecaoiadvh.org.br (CloudPanel)
# Copie para backend/.env no servidor: cp .env.production.example .env

SECRET_KEY=CHANGE_ME_SECRET
DEBUG=False

ALLOWED_HOSTS=apiinspecaoiadvh.org.br,localhost,127.0.0.1

# URL do frontend (ajuste quando o site Node estiver no ar)
CORS_ORIGINS=https://inspecaoiadvh.org.br,https://www.inspecaoiadvh.org.br
CSRF_TRUSTED_ORIGINS=https://apiinspecaoiadvh.org.br

BEHIND_PROXY=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

DATABASE_URL=sqlite:///data/db.sqlite3

# Fotos: prefira Nginx (deploy/cloudpanel/nginx-media.conf). Fallback via Django:
# SERVE_MEDIA=true

ADMIN_EMAIL=admin@ssma.com.br
ADMIN_PASSWORD=ALTERE_ESTA_SENHA_FORTE
ADMIN_NAME=Administrador SSMA
LOG_LEVEL=INFO
ACCESS_TOKEN_EXPIRE_HOURS=8

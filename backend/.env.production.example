# Produção — apiinspecao.iadvh.org.br (CloudPanel)
# Copie para backend/.env no servidor: cp .env.production.example .env

SECRET_KEY=CHANGE_ME_SECRET
DEBUG=False

ALLOWED_HOSTS=apiinspecao.iadvh.org.br,localhost,127.0.0.1

# Frontend
CORS_ORIGINS=https://inspecao.iadvh.org.br,https://www.inspecao.iadvh.org.br
CSRF_TRUSTED_ORIGINS=https://apiinspecao.iadvh.org.br

BEHIND_PROXY=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

GUNICORN_BIND=127.0.0.1:8011

DATABASE_URL=mysql://inspecaodb:SENHA@127.0.0.1:3306/inspecaodb
# PostgreSQL: postgresql://user:pass@127.0.0.1:5432/dbname
# SQLite (dev): sqlite:///data/db.sqlite3

# Fotos: prefira Nginx (deploy/cloudpanel/nginx-media.conf). Fallback via Django:
# SERVE_MEDIA=true

ADMIN_EMAIL=admin@ssma.com.br
ADMIN_PASSWORD=ALTERE_ESTA_SENHA_FORTE
ADMIN_NAME=Administrador SSMA
LOG_LEVEL=INFO
ACCESS_TOKEN_EXPIRE_HOURS=8
